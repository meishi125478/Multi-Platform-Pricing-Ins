{
  "data_dir": "./Data",
  "model_list": ["od"],
  "model_categories": ["bc"],
  "target": "response",
  "weight": "weights",
  "feature_list": [
    "age_owner",
    "gender_owner",
    "plt_zone",
    "carbrand"
  ],
  "categorical_features": [
    "gender_owner",
    "plt_zone",
    "carbrand"
  ],
  "task_type": "regression",
  "prop_test": 0.25,
  "holdout_ratio": 0.25,
  "val_ratio": 0.25,
  "split_strategy": "random",
  "rand_seed": 13,
  "epochs": 50,
  "output_dir": "./Results",
  "use_gpu": true,
  "xgb_max_depth_max": 25,
  "xgb_n_estimators_max": 500,
  "xgb_gpu_id": 0,
  "xgb_cleanup_per_fold": false,
  "xgb_cleanup_synchronize": false,
  "xgb_use_dmatrix": true,
  "xgb_chunk_size": null,
  "stream_split_csv": false,
  "stream_split_chunksize": 200000,
  "ft_use_lazy_dataset": true,
  "ft_predict_batch_size": null,
  "resn_use_lazy_dataset": true,
  "resn_predict_batch_size": null,
  "ft_cleanup_per_fold": false,
  "ft_cleanup_synchronize": false,
  "resn_cleanup_per_fold": false,
  "resn_cleanup_synchronize": false,
  "gnn_cleanup_per_fold": false,
  "gnn_cleanup_synchronize": false,
  "gnn_max_fit_rows": null,
  "gnn_max_predict_rows": null,
  "gnn_predict_chunk_rows": null,
  "optuna_cleanup_synchronize": false,
  "optuna_storage": "./Results/optuna/bayesopt.sqlite3",
  "runner": {
    "mode": "entry",
    "model_keys": ["xgb"],
    "nproc_per_node": 1,
    "max_evals": 50
  }
}
