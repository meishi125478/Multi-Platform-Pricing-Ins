{
  "data_dir": "./Data",
  "data_format": "csv",
  "data_path_template": "{model_name}.{ext}",
  "dtype_map": null,
  "target": "response",
  "weight": "weights",
  "prop_test": 0.25,
  "holdout_ratio": 0.25,
  "val_ratio": 0.25,
  "split_strategy": "random",
  "split_group_col": null,
  "split_time_col": null,
  "split_time_ascending": true,
  "cv_strategy": null,
  "cv_group_col": null,
  "cv_time_col": null,
  "cv_time_ascending": true,
  "cv_splits": null,
  "rand_seed": 13,
  "epochs": 50,
  "model_list": ["od"],
  "model_categories": ["bc"],
  "feature_list": [],
  "categorical_features": [],
  "binary_resp_nme": null,
  "task_type": "regression",
  "output_dir": "./Results",
  "plot_path_style": "nested",
  "use_gpu": true,
  "save_preprocess": false,
  "preprocess_artifact_path": null,
  "bo_sample_limit": null,
  "cache_predictions": false,
  "prediction_cache_dir": null,
  "prediction_cache_format": "parquet",
  "plot_curves": true,
  "ft_num_numeric_tokens": null,
  "ft_oof_folds": null,
  "ft_oof_strategy": null,
  "ft_oof_shuffle": true,
  "resn_weight_decay": 0.0001,
  "final_ensemble": false,
  "final_ensemble_k": 3,
  "final_refit": true,
  "plot": {
    "enable": true,
    "n_bins": 10,
    "oneway": true,
    "oneway_pred": true,
    "pre_oneway": true,
    "lift_models": ["xgb", "resn"],
    "double_lift": true,
    "double_lift_pairs": []
  },
  "optuna_storage": "./Results/optuna/bayesopt.sqlite3",
  "optuna_study_prefix": "pricing_incremental",
  "reuse_best_params": true,
  "runner": {
    "mode": "incremental",
    "use_watchdog": false,
    "idle_seconds": 7200,
    "max_restarts": 50,
    "restart_delay_seconds": 10,
    "incremental_args": [
      "--incremental-dir",
      "./IncrementalBatches",
      "--incremental-template",
      "{model_name}_2025Q1.csv",
      "--merge-keys",
      "policy_id",
      "vehicle_id",
      "--timestamp-col",
      "snapshot_ts",
      "--timestamp-descending",
      "--model-keys",
      "glm",
      "xgb",
      "ft",
      "--max-evals",
      "25",
      "--update-base-data",
      "--plot-curves",
      "--summary-json",
      "./Results/incremental_summary.json"
    ]
  }
}
