  "binary_resp_nme": null,
  "task_type": "regression",
  "prop_test": 0.25,
  "rand_seed": 13,
  "epochs": 50,
  "output_dir": "./ResultsFTUnsupervisedResN",
  "plot_curves": true,
  "plot": {
    "enable": true,
    "n_bins": 10,
    "oneway": true,
    "oneway_pred": true,
    "pre_oneway": true,
    "lift_models": [
      "xgb",
      "resn"
    ],
    "double_lift": true,
    "double_lift_pairs": []
  },
  "env": {
    "OPENBLAS_NUM_THREADS": "1",
    "OMP_NUM_THREADS": "1",
    "BAYESOPT_DDP_BARRIER_DEBUG": 1,
    "TORCH_DISTRIBUTED_DEBUG": "DETAIL",
    "NCCL_DEBUG": "INFO",
    "BAYESOPT_DDP_TIMEOUT_SECONDS": "7200",
    "BAYESOPT_DDP_BARRIER_TIMEOUT": "7200"
  },
  "use_gpu": true,
  "use_resn_data_parallel": false,
  "use_ft_data_parallel": false,
  "use_gnn_data_parallel": false,
  "use_resn_ddp": true,
  "use_ft_ddp": true,
  "use_gnn_ddp": true,
  "ft_role": "unsupervised_embedding",
  "ft_feature_prefix": "ft_emb",
  "stack_model_keys": [
    "resn"
  ],
  "infer_categorical_max_unique": 50,
  "infer_categorical_max_ratio": 0.05,
  "xgb_max_depth_max": 25,
  "xgb_n_estimators_max": 500,
  "optuna_storage": "./ResultsFTUnsupervisedResN/optuna/bayesopt.sqlite3",
  "optuna_study_prefix": "pricing",
  "reuse_best_params": false,
  "best_params_files": {},
  "gnn_use_approx_knn": true,
  "gnn_approx_knn_threshold": 50000,
  "gnn_graph_cache": null,
  "gnn_max_gpu_knn_nodes": 200000,
  "gnn_knn_gpu_mem_ratio": 0.9,
  "gnn_knn_gpu_mem_overhead": 2.0,
  "geo_feature_nmes": [],
  "region_province_col": null,
  "region_city_col": null,
  "region_effect_alpha": 0.0,
  "runner": {
    "mode": "entry",
    "model_keys": [
      "resn"
    ],
    "nproc_per_node": 1,
    "max_evals": 50,
    "plot_curves": true,
    "ft_role": null,
    "use_watchdog": false,
    "idle_seconds": 7200,
    "max_restarts": 50,
    "restart_delay_seconds": 10,
    "incremental_args": [
      "--incremental-dir",
      "./IncrementalBatches",
      "--incremental-template",
      "{model_name}_2025Q1.csv",
      "--merge-keys",
      "policy_id",
      "vehicle_id",
      "--model-keys",
      "glm",
      "xgb",
      "ft",
      "--max-evals",
      "25",
      "--update-base-data"
    ]
  }
